{
  "family": "notification-service",
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::512494867581:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::512494867581:role/notificationServiceTaskRole",
  "containerDefinitions": [
    {
      "name": "notification-service",
      "image": "512494867581.dkr.ecr.ap-south-1.amazonaws.com/book-corner-notification-service:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3004,
          "hostPort": 3004,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "3004"
        },
        {
          "name": "ALLOWED_ORIGINS",
          "value": "*"
        }
      ],
      "secrets": [
        {
          "name": "MONGO_URI",
          "valueFrom": "arn:aws:ssm:ap-south-1:512494867581:parameter/notification-service/MONGO_URI"
        },
        {
          "name": "INTERNAL_JWT_SECRET",
          "valueFrom": "arn:aws:ssm:ap-south-1:512494867581:parameter/notification-service/INTERNAL_JWT_SECRET"
        },
        {
          "name": "USER_JWT_SECRET",
          "valueFrom": "arn:aws:ssm:ap-south-1:512494867581:parameter/notification-service/USER_JWT_SECRET"
        },
        {
          "name": "SMTP_HOST",
          "valueFrom": "arn:aws:ssm:ap-south-1:512494867581:parameter/notification-service/SMTP_HOST"
        },
        {
          "name": "SMTP_PORT",
          "valueFrom": "arn:aws:ssm:ap-south-1:512494867581:parameter/notification-service/SMTP_PORT"
        },
        {
          "name": "SMTP_SECURE",
          "valueFrom": "arn:aws:ssm:ap-south-1:512494867581:parameter/notification-service/SMTP_SECURE"
        },
        {
          "name": "SMTP_USER",
          "valueFrom": "arn:aws:ssm:ap-south-1:512494867581:parameter/notification-service/SMTP_USER"
        },
        {
          "name": "SMTP_PASS",
          "valueFrom": "arn:aws:ssm:ap-south-1:512494867581:parameter/notification-service/SMTP_PASS"
        },
        {
          "name": "SMTP_FROM",
          "valueFrom": "arn:aws:ssm:ap-south-1:512494867581:parameter/notification-service/SMTP_FROM"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/notification-service",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
