{
    "family":  "notification-service",
    "taskRoleArn":  "arn:aws:iam::512494867581:role/notificationServiceTaskRole",
    "executionRoleArn":  "arn:aws:iam::512494867581:role/ecsTaskExecutionRole",
    "networkMode":  "awsvpc",
    "containerDefinitions":  [
                                 {
                                     "name":  "notification-service",
                                     "image":  "512494867581.dkr.ecr.ap-south-1.amazonaws.com/book-corner-notification-service:latest",
                                     "cpu":  0,
                                     "portMappings":  [
                                                          {
                                                              "containerPort":  3004,
                                                              "hostPort":  3004,
                                                              "protocol":  "tcp"
                                                          }
                                                      ],
                                     "essential":  true,
                                     "environment":  [
                                                         {
                                                             "value":  "3004",
                                                             "name":  "PORT"
                                                         },
                                                         {
                                                             "value":  "*",
                                                             "name":  "ALLOWED_ORIGINS"
                                                         },
                                                         {
                                                             "value":  "mongodb+srv://admin:admin@assignment-cluster.ntk8z.mongodb.net/?appName=Assignment-Cluster",
                                                             "name":  "MONGO_URI"
                                                         },
                                                         {
                                                             "value":  "book-corner-internal-token",
                                                             "name":  "INTERNAL_SERVICE_TOKEN"
                                                         },
                                                         {
                                                             "value":  "book-corner-user-secret",
                                                             "name":  "USER_JWT_SECRET"
                                                         }
                                                     ],
                                     "mountPoints":  [

                                                     ],
                                     "volumesFrom":  [

                                                     ],
                                     "logConfiguration":  {
                                                              "logDriver":  "awslogs",
                                                              "options":  {
                                                                              "awslogs-group":  "/ecs/notification-service",
                                                                              "awslogs-region":  "ap-south-1",
                                                                              "awslogs-stream-prefix":  "ecs"
                                                                          }
                                                          },
                                     "systemControls":  [

                                                        ]
                                 }
                             ],
    "requiresCompatibilities":  [
                                    "FARGATE"
                                ],
    "cpu":  "256",
    "memory":  "512"
}